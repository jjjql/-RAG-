{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/uds_embedding_v1.0_frozen.json",
  "title": "UDS Embedding v1.0（契约冻结）",
  "description": "架构冻结：2026-03-26。wire protocolVersion=1；外层 uint32 BE 长度前缀见 UDS_EMBEDDING.md。非兼容变更须递增 protocolVersion 或另立 schema。",
  "oneOf": [
    { "$ref": "#/$defs/EmbedRequest" },
    { "$ref": "#/$defs/PingRequest" },
    { "$ref": "#/$defs/EmbedSuccessResponse" },
    { "$ref": "#/$defs/PongResponse" },
    { "$ref": "#/$defs/ErrorResponse" }
  ],
  "$defs": {
    "EmbedRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "requestId", "text"],
      "properties": {
        "protocolVersion": { "type": "integer", "const": 1 },
        "requestId": { "type": "string", "format": "uuid" },
        "traceId": { "type": "string", "format": "uuid" },
        "kind": { "type": "string", "const": "embed", "description": "可省略，省略即 embed" },
        "text": { "type": "string", "minLength": 1 },
        "model": { "type": "string" }
      }
    },
    "PingRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "requestId", "kind"],
      "properties": {
        "protocolVersion": { "type": "integer", "const": 1 },
        "requestId": { "type": "string", "format": "uuid" },
        "traceId": { "type": "string", "format": "uuid" },
        "kind": { "type": "string", "const": "ping" }
      }
    },
    "EmbedSuccessResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "requestId", "dimensions", "embedding", "model"],
      "properties": {
        "protocolVersion": { "type": "integer", "const": 1 },
        "requestId": { "type": "string", "format": "uuid" },
        "dimensions": { "type": "integer", "minimum": 1 },
        "embedding": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 1
        },
        "model": { "type": "string", "minLength": 1 }
      }
    },
    "PongResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "requestId", "kind"],
      "properties": {
        "protocolVersion": { "type": "integer", "const": 1 },
        "requestId": { "type": "string", "format": "uuid" },
        "kind": { "type": "string", "const": "pong" },
        "serverVersion": { "type": "string" }
      }
    },
    "ErrorResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "requestId", "error"],
      "properties": {
        "protocolVersion": { "type": "integer", "const": 1 },
        "requestId": { "type": "string", "format": "uuid" },
        "error": {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "message"],
          "properties": {
            "code": {
              "type": "string",
              "enum": [
                "UNSUPPORTED_VERSION",
                "VALIDATION_ERROR",
                "FRAME_TOO_LARGE",
                "MODEL_NOT_READY",
                "MODEL_OOM",
                "INFERENCE_FAILED",
                "INTERNAL"
              ]
            },
            "message": { "type": "string", "minLength": 1 },
            "details": { "type": "object" }
          }
        }
      }
    }
  }
}
